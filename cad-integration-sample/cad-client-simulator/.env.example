# JBR (JetBrains Runtime) 配置
# 复制此文件为 .env 并修改为你的 JBR 路径

# JBR 安装路径（必须是包含 JCEF 的版本）
JBR_HOME=/home/beam/tools/jbr_jcef-17.0.11-linux-x64-b1312.2

# macOS 示例:
# JBR_HOME=/Users/user/jbr/jbr_jcef-17.0.10-osx-x64-b1087.23/Contents/Home

# Windows 示例:
# JBR_HOME=C:/jbr/jbr_jcef-17.0.10-windows-x64-b1087.23
