Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "stockQuantity",
        "operator": "LESS_THAN_EQUALS",
        "value": 100
      }
    ]
  }
}

> {%
    client.test("LESS_THAN_EQUALS 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个库存小于等于100的产品");
    });
%}


### 6.3 BETWEEN 查询
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "unitPrice",
        "operator": "BETWEEN",
        "value": 500,
        "secondValue": 3000
      }
    ]
  }
}

> {%
    client.test("BETWEEN 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个单价在500-3000之间的产品");
    });
%}

