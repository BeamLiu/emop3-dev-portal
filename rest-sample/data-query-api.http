### 16.1 多个 IN 条件组合（AND）
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "name",
        "operator": "IN",
        "value": ["智能手机", "笔记本电脑", "办公椅"]
      },
      {
        "field": "stockQuantity",
        "operator": "IN",
        "value": [100, 50, 200]
      }
    ]
  }
}

> {%
    client.test("多个 IN 条件 AND 组合成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length >= 1, "应该至少查询到1个产品");
        client.log("✅ 多个 IN 条件 AND 组合查询成功");
    });
%}

### 16.2 IN 与 NOT_IN 组合
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
