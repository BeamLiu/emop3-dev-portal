###############################################
# 步骤11: NULL 值查询
###############################################

### 11.1 IS_NULL 查询
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
