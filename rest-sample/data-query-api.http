  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "stockQuantity",
        "operator": "IN",
        "value": [100, 200, 500]
      }
    ]
  }
}

> {%
    client.test("IN 查询（整数）成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length === 3, "应该查询到3个产品");
        client.log("✅ IN 查询（整数）成功，查询到 " + response.body.length + " 个产品");
    });
%}


