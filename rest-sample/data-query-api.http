x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "unitPrice",
        "operator": "GREATER_THAN",
        "value": 1000
      }
    ]
  }
}

> {%
    client.test("GREATER_THAN 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个单价大于1000的产品");
    });
%}

