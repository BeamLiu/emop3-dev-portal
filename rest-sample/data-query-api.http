### 7.1 LIKE 查询
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "name",
        "operator": "LIKE",
        "value": "%电%"
      }
    ]
  }
}

> {%
    client.test("LIKE 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个名称包含'电'的产品");
    });
%}


###############################################
# 步骤8: 复合条件查询（AND/OR）
###############################################

### 8.1 AND 复合查询
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "isActive",
        "operator": "EQUALS",
        "value": true
      },
      {
        "field": "unitPrice",
        "operator": "GREATER_THAN",
        "value": 1000
      }
    ]
  }
}

> {%
    client.test("AND 复合查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个激活且单价大于1000的产品");
    });
%}

### 8.2 OR 复合查询
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "OR",
    "conditions": [
      {
        "field": "name",
        "operator": "EQUALS",
        "value": "智能手机"
      },
      {
        "field": "name",
        "operator": "EQUALS",
        "value": "办公椅"
      }
    ]
  }
}

> {%
    client.test("OR 复合查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length === 2, "应该查询到2个产品");
        client.log("✅ OR 复合查询成功");
    });
%}


### 8.3 嵌套条件查询（AND 中包含 OR）
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "isActive",
        "operator": "EQUALS",
        "value": true
      },
      {
        "type": "OR",
        "conditions": [
          {
            "field": "name",
            "operator": "LIKE",
            "value": "%手机%"
          },
          {
            "field": "name",
            "operator": "LIKE",
            "value": "%电脑%"
          }
        ]
      }
    ]
  }
}

> {%
    client.test("嵌套条件查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("✅ 嵌套条件查询成功，查询到 " + response.body.length + " 个产品");
    });
%}

