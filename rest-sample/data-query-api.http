###############################################
# 步骤3: 基础查询操作
###############################################

### 3.1 查询所有 ProductItem（不分页）
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": []
  }
}

> {%
    client.test("查询所有产品成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(Array.isArray(response.body), "返回结果应为数组");
        client.log("查询到 " + response.body.length + " 个产品");
    });
%}

### 3.2 查询所有 ProductItem（分页）
POST {{baseUrl}}/api/data/query/ProductItem/page
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": []
  },
  "pagination": {
    "pageNumber": 0,
    "pageSize": 10
  }
}

> {%
    client.test("分页查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.content !== undefined, "应包含content字段");
        client.log("总记录数: " + response.body.totalElements);
        client.log("当前页记录数: " + response.body.content.length);
    });
%}


###############################################
# 步骤4: EQUALS 查询
###############################################

### 4.1 按字符串字段查询（EQUALS）
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "name",
        "operator": "EQUALS",
        "value": "智能手机"
      }
    ]
  }
}

> {%
    client.test("EQUALS 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length > 0, "应该查询到结果");
        client.assert(response.body[0].name === "智能手机", "名称应匹配");
    });
%}

### 4.2 按布尔字段查询（EQUALS）
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "isActive",
        "operator": "EQUALS",
        "value": true
      }
    ]
  }
}

> {%
    client.test("布尔字段查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.log("查询到 " + response.body.length + " 个激活的产品");
    });
%}


###############################################
# 步骤5: IN 操作查询（重点测试）
###############################################

### 5.1 IN 查询 - 字符串字段
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "name",
        "operator": "IN",
        "value": ["智能手机", "笔记本电脑", "办公椅"]
      }
    ]
  }
}

> {%
    client.test("IN 查询（字符串）成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length === 3, "应该查询到3个产品");
        client.log("✅ IN 查询成功，查询到 " + response.body.length + " 个产品");
    });
%}

