    "type": "AND",
    "conditions": [
      {
        "field": "name",
        "operator": "NOT_IN",
        "value": ["智能手机", "笔记本电脑"]
      }
    ]
  }
}

> {%
    client.test("NOT_IN 查询成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length >= 3, "应该查询到至少3个产品");
        client.log("✅ NOT_IN 查询成功，查询到 " + response.body.length + " 个产品");
    });
%}


