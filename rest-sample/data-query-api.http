        "field": "name",
        "operator": "NOT_IN",
        "value": ["书桌"]
      }
    ]
  }
}

> {%
    client.test("IN 与 NOT_IN 组合成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length === 4, "应该查询到4个产品");
        client.log("✅ IN 与 NOT_IN 组合查询成功");
    });
%}


### 16.3 IN 查询与 LIKE 组合
POST {{baseUrl}}/api/data/query/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "conditions": {
    "type": "AND",
    "conditions": [
      {
        "field": "productCode",
        "operator": "IN",
        "value": ["PHONE-001", "LAPTOP-001", "CHAIR-001"]
      },
      {
        "field": "name",
        "operator": "LIKE",
        "value": "%电%"
      }
    ]
  }
}

> {%
    client.test("IN 与 LIKE 组合成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.length >= 1, "应该至少查询到1个产品");
        client.log("✅ IN 与 LIKE 组合查询成功");
    });
%}

