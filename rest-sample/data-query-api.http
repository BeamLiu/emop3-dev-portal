### 数据查询 API 测试样例
### 说明：本测试包含 DSL 创建类型、数据创建和各种查询操作（包括 IN 操作）
### 按顺序执行即可完成完整的数据查询功能测试

### 基础URL配置
@baseUrl = http://localhost:870/webconsole
@contentType = application/json
@userHeader = {"userId":-1,"authorities":["SYSTEM"]}

### 动态变量
@timestamp = {{$timestamp}}
@item1Id = 
@item2Id = 
@item3Id = 
@item4Id = 
@item5Id = 

###############################################
# 步骤1: 使用 DSL 创建自定义类型
###############################################

### 1.1 创建继承自 ItemRevision 的自定义类型，包含各种属性类型
POST {{baseUrl}}/api/dsl/execute
Content-Type: text/plain
x-user: {{userHeader}}

create type com.example.ProductItem extends io.emop.model.common.ItemRevision {
    // 字符串类型
    attribute productCode: String {
        required: true
        description: "产品编码"
    }
    
    // 整数类型
    attribute stockQuantity: Integer {
        description: "库存数量"
    }
    
    // 浮点数类型
    attribute unitPrice: Double {
        description: "单价"
    }
    
    // 布尔类型
    attribute isActive: Boolean {
        description: "是否激活"
    }
    
    // 日期类型
    attribute manufactureDate: java.sql.Date {
        description: "生产日期"
    }
    
    // 时间戳类型
    attribute lastUpdateTime: Timestamp {
        description: "最后更新时间"
    }
    
    // Object 类型 - 用于存储复杂对象
    attribute specifications: Object {
        description: "产品规格"
    }
    
    // Object 类型 - 用于存储分类信息
    attribute categoryInfo: Object {
        description: "分类信息"
    }
    
    schema: SAMPLE
    tableName: Product_Item
} if not exists

> {%
    client.test("DSL 执行成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
    });
    
    if (response.status === 200) {
        client.log("✅ 自定义类型 ProductItem 创建成功");
    }
%}


###############################################
# 步骤2: 创建测试数据
###############################################

### 2.1 创建产品1 - 电子产品
POST {{baseUrl}}/api/data/ProductItem
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "data": {
    "code": "PROD-ELEC-{{timestamp}}-001",
    "revId": "A",
    "name": "智能手机",
    "productCode": "PHONE-001",
    "stockQuantity": 100,
    "unitPrice": 2999.99,
    "isActive": true,
    "manufactureDate": "2024-01-15",
    "lastUpdateTime": "2024-10-15T10:30:00",
    "specifications": {
      "screen": "6.5英寸",
      "memory": "8GB",
      "storage": "256GB",
      "battery": "4500mAh"
    },
    "categoryInfo": {
      "category": "电子产品",
      "subCategory": "智能手机",
      "brand": "华为"
    }
  }
}

> {%
    client.test("创建产品1成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.id !== null, "产品ID不应为空");
    });
    
    if (response.status === 200) {
        client.global.set("item1Id", response.body.id);
        client.log("✅ 产品1创建成功: ID=" + response.body.id);
    }
%}


