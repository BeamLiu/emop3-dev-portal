###############################################
# 8. 批量删除BOM行
###############################################
DELETE {{baseUrl}}/api/bom/lines/batch
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "cascade": true,
  "items": [
    {
      "parent": {
        "id": {{parentItemId}}
      },
      "child": {
        "id": {{child2ItemId}}
      }
    },
    {
      "parent": {
        "id": {{newParentItemId}}
      },
      "child": {
        "id": {{child3ItemId}}
      }
    }
  ]
}

> {%
    client.test("请求成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
    });
    
    client.test("批量删除成功", function() {
        client.log("实际删除数量: " + response.body.deletedCount);
        client.assert(response.body.deletedCount === 2, "应删除2个BomLine，实际删除: " + response.body.deletedCount+", 这个测试用例有可能失败，由于缓存的更新的时机，可以暂时忽略该失败的用例");
    });
    
    if (response.status === 200) {
        client.log("✅ 批量删除" + response.body.deletedCount + "个BOM行成功");
    }
%}

