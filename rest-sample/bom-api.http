### BOM API 测试样例
### 说明：本测试会自动创建测试数据，无需手动填写ID
### 按顺序执行即可完成完整的BOM功能测试

### 基础URL配置
@baseUrl = http://localhost:870/webconsole
@contentType = application/json
@userHeader = {"userId":-1,"authorities":["SYSTEM"]}

### 动态变量（由测试自动生成和填充）
@timestamp = {{$timestamp}}
@parentItemId = 
@childItemId = 
@child2ItemId = 
@child3ItemId = 
@newParentItemId = 
@parentCode = 
@childCode = 
@child2Code = 
@child3Code = 
@newParentCode =

###############################################
# 准备测试数据
###############################################

### 步骤0.1: 创建父件 (Parent Item)
POST {{baseUrl}}/api/data/ItemRevision
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "data": {
    "code": "BOM-PARENT-{{timestamp}}",
    "revId": "A",
    "name": "BOM测试父件"
  }
}


> {%
    client.test("创建父件成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
        client.assert(response.body.id !== null, "父件ID不应为空");
    });
    
    if (response.status === 200) {
        client.global.set("parentItemId", response.body.id);
        client.global.set("parentCode", response.body.code);
        client.log("✅ 父件创建成功: ID=" + response.body.id + ", Code=" + response.body.code);
    }
%}


