%}

###############################################
# 7.7 根据子级和RevisionRule获取所有父级Revisionable
###############################################
POST {{baseUrl}}/api/bom/parents
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "child": {
    "id": {{child2ItemId}}
  },
  "revisionRule": "PRECISE"
}

> {%
    client.test("请求成功", function() {
        client.assert(response.status === 200, "响应状态应为200");
    });
    
    client.test("返回父级列表", function() {
        client.assert(Array.isArray(response.body), "返回结果应为数组");
        client.log("Child2的父级数量: " + response.body.length);
        response.body.forEach((parent, index) => {
            client.log(`  [${index}] parent ID: ${parent.id}, code: ${parent.code}, revId: ${parent.revId}`);
        });
    });
    
    if (response.status === 200) {
        client.log("✅ 获取父级Revisionable成功");
    }
%}

