### 步骤0.5: 创建新父件 (New Parent Item for move test)
POST {{baseUrl}}/api/data/ItemRevision
Content-Type: {{contentType}}
x-user: {{userHeader}}

{
  "data": {
    "code": "BOM-NEWPARENT-{{timestamp}}",
    "revId": "A",
    "name": "BOM测试新父件"
  }
}

> {%
    client.test("创建新父件成功", function() {
